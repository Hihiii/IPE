{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 4 Self-Review Optimization",
  "type": "object",
  "required": ["no_changes_needed"],
  "properties": {
    "no_changes_needed": { "type": "boolean" },
    "optimization_pass": {
      "type": "object",
      "properties": {
        "iteration": { "type": "integer", "minimum": 2, "maximum": 2 },
        "changes_made": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["category", "before", "after", "reason"],
            "properties": {
              "category": { "type": "string" },
              "before": { "type": "string" },
              "after": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
    "optimized_prompt_package": {
      "type": ["object", "null"],
      "properties": {
            "subject": { "type": "string" },
            "composition": { "type": "object" },
            "style_and_lighting": { "type": "object" },
            "background": { "type": "string" },
            "material": { "type": "string" },
            "atmosphere": { "type": "string" },
            "constraints": { "type": "object" }
          }
        }
      }
    }
  }
}
