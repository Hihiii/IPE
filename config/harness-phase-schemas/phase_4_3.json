{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 4.3 Delivery Package",
  "type": "object",
  "required": ["model_target", "positive_prompt", "negative_prompt", "suggest_resolution", "output_contract"],
  "properties": {
    "model_target": { "type": "string", "enum": ["z_image"] },
    "renderer_profile": { "type": "string" },
    "publication_mode": { "type": "string" },
    "positive_prompt": { "type": "string" },
    "negative_prompt": { "type": "string" },
    "locked_constraints": { "type": "array", "items": { "type": "string" } },
    "exact_text": { "type": "array", "items": { "type": "string" } },
    "suggest_resolution": { "type": "string" },
    "output_contract": {
      "type": "object",
      "properties": {
        "final_prompt_ready": { "type": "boolean" },
        "renderer_fields_normalized": { "type": "boolean" },
        "no_raw_internal_package": { "type": "boolean" }
      }
    }
  }
}
