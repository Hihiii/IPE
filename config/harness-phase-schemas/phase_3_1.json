{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 3.1 Prompt Package",
  "type": "object",
  "required": ["original_prompt", "subject", "composition", "style_and_lighting"],
  "properties": {
    "original_prompt": { "type": "string" },
    "type": {
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "use_case": { "type": "string" }
      }
    },
    "subject": { "type": "string" },
    "composition": {
      "type": "object",
      "properties": {
        "framing": { "type": "string" },
        "layout": { "type": "string" },
        "subject_placement": { "type": "string" },
        "depth_planes": { "type": "string" },
        "negative_space": { "type": "string" }
      }
    },
    "style_and_lighting": {
      "type": "object",
      "properties": {
        "visual_language": { "type": "string" },
        "lighting": { "type": "object" },
        "color_script": { "type": "object" },
        "exposure": { "type": "string" },
        "lens": { "type": "string" }
      }
    },
    "background": { "type": "string" },
    "material": { "type": "string" },
    "atmosphere": { "type": "string" },
    "constraints": {
      "type": "object",
      "properties": {
        "must_keep": { "type": "array", "items": { "type": "string" } },
        "no_extra_elements": { "type": "array", "items": { "type": "string" } }
      }
    },
    "output_format": {
      "type": "object",
      "properties": {
        "aspect_ratio": { "type": "string" },
        "output_medium": { "type": "string" }
      }
    },
    "publication_layout": { "type": "object" },
    "quality_tags": { "type": "array", "items": { "type": "string" } },
    "avoid": { "type": "array", "items": { "type": "string" } }
  }
}
