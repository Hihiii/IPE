{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 3 Scene Blueprint",
  "type": "object",
  "required": ["subject", "environment", "camera", "lighting_diagram", "atmosphere"],
  "properties": {
    "subject": {
      "type": "object",
      "required": ["type", "description"],
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "pose_or_arrangement": { "type": "string" },
        "gaze_direction": { "type": "string" }
      }
    },
    "environment": {
      "type": "object",
      "properties": {
        "location": { "type": "string" },
        "subject_to_bg_distance": { "type": "string" },
        "set_dressing": { "type": "array", "items": { "type": "string" } }
      }
    },
    "camera": {
      "type": "object",
      "properties": {
        "lens": { "type": "string" },
        "aperture": { "type": "string" },
        "angle": { "type": "string" },
        "framing": { "type": "string" },
        "shooting_distance_m": { "type": "number" }
      }
    },
    "lighting_diagram": {
      "type": "object",
      "properties": {
        "key_light": { "type": "object" },
        "fill_light": { "type": "object" },
        "rim_light": { "type": "object" }
      }
    },
    "atmosphere": {
      "type": "object",
      "properties": {
        "mood": { "type": "string" },
        "haze": { "type": "string" },
        "bokeh_type": { "type": "string" },
        "grain": { "type": "string" }
      }
    }
  }
}
