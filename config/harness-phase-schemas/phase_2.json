{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 2 Cinematic Enrichment",
  "type": "object",
  "required": [
    "color_script", "lighting_intent", "lens_strategy",
    "exposure_strategy", "composition", "generator_translation"
  ],
  "properties": {
    "color_script": {
      "type": "object",
      "required": ["palette_type", "dominant_colors", "saturation_strategy", "color_grading_intent"],
      "properties": {
        "palette_type": { "type": "string", "enum": ["complementary", "analogous", "monochromatic", "triadic", "split_complementary"] },
        "dominant_colors": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "saturation_strategy": { "type": "string", "enum": ["muted", "vibrant", "selective", "desaturated"] },
        "color_grading_intent": { "type": "string" }
      }
    },
    "lighting_intent": {
      "type": "object",
      "required": ["key_quality", "key_modifier", "ratio", "color_temperature_strategy"],
      "properties": {
        "key_quality": { "type": "string", "enum": ["hard", "soft", "diffused", "specular", "wrap_around"] },
        "key_modifier": { "type": "string" },
        "ratio": { "type": "string" },
        "color_temperature_strategy": { "type": "string", "enum": ["matched", "mixed_CTO", "mixed_CTB", "gel_accent"] },
        "rim_or_separation": { "type": "boolean" },
        "background_treatment": { "type": "string", "enum": ["flat", "gradient", "textured", "gobo", "patterned"] }
      }
    },
    "lens_strategy": {
      "type": "object",
      "required": ["focal_length_category", "compression", "aperture_intent", "working_distance", "camera_height"],
      "properties": {
        "focal_length_category": { "type": "string", "enum": ["wide_angle", "wide_to_normal", "standard", "short_telephoto", "telephoto", "ultra_wide"] },
        "compression": { "type": "string", "enum": ["low", "moderate", "strong", "extreme"] },
        "aperture_intent": { "type": "string", "enum": ["shallow_DoF", "deep_focus", "medium"] },
        "working_distance": { "type": "string", "enum": ["close", "moderate", "far"] },
        "camera_height": { "type": "string", "enum": ["low_angle", "eye_level", "high_angle", "overhead"] },
        "distortion_character": { "type": "string", "enum": ["natural", "slight_warp", "anamorphic_feel"] }
      }
    },
    "exposure_strategy": {
      "type": "object",
      "required": ["style", "contrast_ratio"],
      "properties": {
        "style": { "type": "string", "enum": ["high_key", "low_key", "middle_key", "silhouette", "chiaroscuro", "flat_diffuse"] },
        "contrast_ratio": { "type": "string", "enum": ["low", "medium", "high", "extreme"] }
      }
    },
    "composition": {
      "type": "object",
      "required": ["rule", "depth_layers", "focal_priority"],
      "properties": {
        "rule": { "type": "string" },
        "depth_layers": { "type": "integer", "minimum": 2, "maximum": 4 },
        "focal_priority": { "type": "array", "items": { "type": "string" } },
        "breathing_room": { "type": "string", "enum": ["tight", "comfortable", "generous"] }
      }
    },
    "pose_design": {
      "type": "object",
      "properties": {
        "boring_pose_diagnosis": { "type": "array", "items": { "type": "string" } },
        "pose_design_strategies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "visual_richness": {
      "type": "object",
      "properties": {
        "narrative_layering": { "type": "object" },
        "depth_creation_methods": { "type": "array", "items": { "type": "string" } }
      }
    },
    "generator_translation": {
      "type": "object",
      "required": ["visible_lighting_effect", "visible_depth_effect", "visible_material_effect", "visible_composition_effect"],
      "properties": {
        "visible_lighting_effect": { "type": "string" },
        "visible_depth_effect": { "type": "string" },
        "visible_material_effect": { "type": "string" },
        "visible_composition_effect": { "type": "string" },
        "model_risk": { "type": "array", "items": { "type": "string" } },
        "corrective_terms": { "type": "array", "items": { "type": "string" } },
        "avoid_in_prompt": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
